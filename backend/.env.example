# WFM Platform — переменные окружения
# Скопируй в .env и заполни значения

# JWT
SECRET_KEY=change-this-to-a-random-secret-key-at-least-32-chars
ACCESS_TOKEN_EXPIRE_MINUTES=480

# WFM собственная база (SQLite — путь к файлу)
WFM_DATABASE_URL=sqlite:///./wfm.db

# Naumen PostgreSQL (read-only)
NCC_DB_HOST=telesales-service.nau.team
NCC_DB_NAME=nccrep
NCC_DB_USER=readonly
NCC_DB_PASSWORD=
NCC_DB_PORT=5432

# Naumen REST API
NCC_API_BASE_URL=https://telesales-service.nau.team/api/v2
NCC_API_USERNAME=shaiderman.k
FX_API_KEY=

# CORS — адреса фронтенда через запятую
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
